# ===========================================================================
# Emet — Environment Configuration
# ===========================================================================
# Copy to .env and fill in values. All keys are optional — Emet degrades
# gracefully when sources are unavailable. Demo mode works with no keys.

# ---------------------------------------------------------------------------
# Data sources — Investigation
# ---------------------------------------------------------------------------

# OpenSanctions (sanctions screening, PEP lists)
# Get key: https://www.opensanctions.org/api/
OPENSANCTIONS_API_KEY=

# OpenCorporates (corporate registry search, 200M+ companies)
# Get key: https://api.opencorporates.com/
OPENCORPORATES_API_TOKEN=

# UK Companies House (UK company data — free API key)
# Get key: https://developer.company-information.service.gov.uk/manage-applications
COMPANIES_HOUSE_API_KEY=

# ICIJ Offshore Leaks (Panama Papers, Pandora Papers — no key needed)
# Endpoint: https://offshoreleaks.icij.org/api/v1/reconcile

# GLEIF LEI (Legal Entity Identifiers — no key needed)
# Endpoint: https://api.gleif.org/api/v1

# SEC EDGAR (US company filings — no key needed, but set a User-Agent)
# Required: https://www.sec.gov/os/accessing-edgar-data
EDGAR_USER_AGENT=YourApp/1.0 (your@email.com)

# Congressional STOCK Act disclosures (no key needed)
# Point at the Sovereign congress_scraper's output dir to bridge its
# transactions.json; leave unset to fall back to the standalone House Clerk
# feed puller (emet/ftm/external/congress.py).
EMET_CONGRESS_DATA_DIR=

# FEC / OpenFEC (campaign finance — DEMO_KEY works for light use)
# Get key: https://api.open.fec.gov/developers/
FEC_API_KEY=

# CourtListener / RECAP (federal court records — works unauthenticated at a
# lower rate limit; a token raises the limit)
# Get token: https://www.courtlistener.com/help/api/rest/
COURTLISTENER_API_TOKEN=

# ---------------------------------------------------------------------------
# Data sources — Blockchain
# ---------------------------------------------------------------------------

# Etherscan (Ethereum blockchain explorer)
# Get key: https://etherscan.io/myapikey
ETHERSCAN_API_KEY=

# Solana (public JSON-RPC + Solscan — no key needed)
# Endpoint: https://api.mainnet-beta.solana.com

# ---------------------------------------------------------------------------
# Data sources — News / OSINT
# ---------------------------------------------------------------------------

# GDELT (global news monitoring — no key needed)
# Endpoint: https://api.gdeltproject.org/api/v2/

# SpiderFoot (OSINT reconnaissance — self-hosted)
# Install: https://github.com/smicallef/spiderfoot
SPIDERFOOT_HOST=http://localhost:5001

# ---------------------------------------------------------------------------
# Data sources — Documents
# ---------------------------------------------------------------------------

# Datashare (ICIJ document platform — self-hosted)
DATASHARE_HOST=http://localhost:8080

# DocumentCloud (document hosting for journalists)
# Get key: https://accounts.muckrock.com/
DOCUMENTCLOUD_USERNAME=
DOCUMENTCLOUD_PASSWORD=

# ---------------------------------------------------------------------------
# LLM providers (for agent decision-making)
# ---------------------------------------------------------------------------

# Anthropic Claude (recommended)
ANTHROPIC_API_KEY=

# OpenAI (alternative)
OPENAI_API_KEY=

# Ollama (local, free)
OLLAMA_HOST=http://localhost:11434

# ---------------------------------------------------------------------------
# Notifications (for watchlist alerts)
# ---------------------------------------------------------------------------

# Webhook URL for alert delivery (Slack, Discord, Mattermost, email relay)
# emet watch run --notify webhook
EMET_WEBHOOK_URL=

# ---------------------------------------------------------------------------
# Infrastructure (optional — for production deployments)
# ---------------------------------------------------------------------------

# Database (for persistent sessions, multi-tenancy)
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/emet

# Redis (for caching, rate limiting)
REDIS_URL=redis://localhost:6379/0

# Aleph (OCCRP investigative platform)
ALEPH_HOST=http://localhost:8080
ALEPH_API_KEY=
